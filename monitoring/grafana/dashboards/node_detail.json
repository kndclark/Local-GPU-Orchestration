      "title": "GPU Utilization",
      "type": "timeseries",
      "targets": [
        { "expr": "worker_gpu_utilization_percent{node_id=\"$node_id\"}", "legendFormat": "GPU — {{ model }}", "refId": "A" },
        { "expr": "worker_gpu_memory_utilization_percent{node_id=\"$node_id\"}", "legendFormat": "Memory — {{ model }}", "refId": "B" },
        { "expr": "worker_gpu_encoder_utilization_percent{node_id=\"$node_id\"}", "legendFormat": "Encoder — {{ model }}", "refId": "C" },
        { "expr": "worker_gpu_decoder_utilization_percent{node_id=\"$node_id\"}", "legendFormat": "Decoder — {{ model }}", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": false },
          "unit": "decmbytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
