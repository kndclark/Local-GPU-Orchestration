      "title": "GPU Count",
      "type": "stat",
      "targets": [
        { "expr": "node_gpu_count{node_id=\"$node_id\"}", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
