      "type": "timeseries",
      "targets": [
        { "expr": "worker_gpu_clock_core_mhz{node_id=\"$node_id\"}", "legendFormat": "Core — GPU {{ gpu_index }}", "refId": "A" },
        { "expr": "worker_gpu_clock_memory_mhz{node_id=\"$node_id\"}", "legendFormat": "Memory — GPU {{ gpu_index }}", "refId": "B" }
