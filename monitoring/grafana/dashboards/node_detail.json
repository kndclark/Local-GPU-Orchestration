        { "expr": "worker_gpu_vram_used_mb{node_id=\"$node_id\"}", "legendFormat": "Used — GPU {{ gpu_index }}", "refId": "A" },
        { "expr": "worker_gpu_vram_free_mb{node_id=\"$node_id\"}", "legendFormat": "Free — GPU {{ gpu_index }}", "refId": "B" },
        { "expr": "worker_gpu_vram_total_mb{node_id=\"$node_id\"}", "legendFormat": "Total — GPU {{ gpu_index }}", "refId": "C" }
